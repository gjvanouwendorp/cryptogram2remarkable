# Kopieer naar .env en vul in. .env staat in .gitignore — nooit committen.

# Playwright persistent context (bevat de ingelogde VK/DPG-sessie).
# Eenmalig lokaal aanmaken via `c2rm login`, daarna naar de VPS kopiëren.
C2RM_PROFILE_DIR=./profile

# Waar runtime-output (raw dump, genormaliseerd model, PDF, state) landt.
C2RM_DATA_DIR=./data

# Doelmap op de reMarkable (rmapi-pad).
C2RM_RM_FOLDER=/Cryptogrammen

# Layout: single_page (rooster links + clues rechts) of grid_first (rooster op eigen pagina).
C2RM_LAYOUT=single_page

# Browser tegen Akamai bot-detectie. "chrome" = echte Google Chrome (aanbevolen).
# Leeg = patchright-Chromium (kan door Akamai geweigerd worden).
C2RM_BROWSER_CHANNEL=chrome
# Scrape headless draaien? false = headed (nodig als headless alsnog geblokkeerd
# wordt; draai dan onder xvfb-run op de VPS).
C2RM_HEADLESS=true

C2RM_TIMEZONE=Europe/Amsterdam
C2RM_LOG_LEVEL=INFO

# Optioneel: alert bij sessie-expiry/fout (leeg = uit).
C2RM_NOTIFY_EMAIL=
C2RM_SMTP_URL=
